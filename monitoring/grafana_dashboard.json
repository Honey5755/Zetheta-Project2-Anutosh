{
  "__meta": {
    "project": "FDE-9B — SAP S/4HANA to Zetheta FinSight",
    "projectCode": "493560B",
    "author": "Anutosh Mishra",
    "deliverable": "D6 — Monitoring & Alerting",
    "note": "Importable Grafana dashboard model for panels MON-001..MON-012 (Appendix F)."
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "-- Grafana --",
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "style": "dark",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "Asia/Kolkata",
  "title": "Meridian to FinSight Integration - Operations",
  "uid": "meridian-finsight-ops",
  "tags": ["fde-9b", "meridian", "finsight", "integration"],
  "templating": {
    "list": [
      {
        "name": "domain",
        "label": "Domain",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "query": "GeneralLedger,AccountsPayable,AccountsReceivable,CostCentre,ProfitCentre,MaterialLedger,PurchaseOrders,SalesOrders,FixedAssets,BankStatements,BudgetActual,Inventory"
      },
      {
        "name": "company_code",
        "label": "Company Code",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "query": "MC01,MC02,MC03"
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "multi": false,
        "includeAll": false,
        "current": { "text": "prod", "value": "prod" },
        "query": "prod,staging"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "MON-001 Pipeline Health Overview",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "GREEN if all domains synced within SLA, YELLOW if any >2h stale, RED if any >4h stale or last run failed.",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "pipeline:health:state{environment=\"$environment\"}", "legendFormat": "pipeline health" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "GREEN", "color": "green" }, "1": { "text": "YELLOW", "color": "yellow" }, "2": { "text": "RED", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 } ] }
        }
      }
    },
    {
      "id": 2,
      "title": "MON-002 Throughput (Records/Sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-domain processing rate. Warning if <50% of 7-day same-slot baseline.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "rate(records_processed_total{domain=~\"$domain\",environment=\"$environment\"}[5m])", "legendFormat": "{{domain}} / {{operation}}" },
        { "refId": "B", "expr": "records:baseline:domain{domain=~\"$domain\"}", "legendFormat": "{{domain}} baseline" }
      ],
      "fieldConfig": { "defaults": { "unit": "rps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 3,
      "title": "MON-003 Latency Distribution (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "P95 end-to-end / API latency. Warning if P95 > 5s.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, rate(api_duration_seconds_bucket{environment=\"$environment\"}[5m]))", "legendFormat": "P95" },
        { "refId": "B", "expr": "histogram_quantile(0.50, rate(api_duration_seconds_bucket{environment=\"$environment\"}[5m]))", "legendFormat": "P50" },
        { "refId": "C", "expr": "histogram_quantile(0.99, rate(api_duration_seconds_bucket{environment=\"$environment\"}[5m]))", "legendFormat": "P99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 5 } ] }
        }
      }
    },
    {
      "id": 4,
      "title": "MON-004 Error Rate (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Error percentage by error_class. Critical (P1) if > 5%.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(errors_total{environment=\"$environment\"}[5m])) by (error_class) / sum(rate(requests_total{environment=\"$environment\"}[5m])) by (error_class) * 100", "legendFormat": "{{error_class}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 5 } ] }
        }
      }
    },
    {
      "id": 5,
      "title": "MON-005 DLQ Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Dead-letter queue backlog with 24h trend. Critical (P1) if > 500.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "refId": "A", "expr": "kafka_consumer_group_lag{topic=\"dlq\",environment=\"$environment\"}", "legendFormat": "DLQ depth" },
        { "refId": "B", "expr": "avg_over_time(kafka_consumer_group_lag{topic=\"dlq\",environment=\"$environment\"}[24h])", "legendFormat": "24h trend" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 500 } ] }
        }
      }
    },
    {
      "id": 6,
      "title": "MON-006 Reconciliation Status",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Last recon verdict per domain (RECONCILED/VARIANCE/BREAK) with variance amount. BREAK => P2.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "refId": "A", "expr": "recon_status{domain=~\"$domain\",environment=\"$environment\"}", "legendFormat": "{{domain}}", "format": "table", "instant": true },
        { "refId": "B", "expr": "recon_variance_amount{domain=~\"$domain\",environment=\"$environment\"}", "legendFormat": "{{domain}} variance", "format": "table", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "RECONCILED", "color": "green" }, "1": { "text": "VARIANCE", "color": "yellow" }, "2": { "text": "BREAK", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "MON-007 SAP System Health",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "RFC pool utilisation (<=50 conns), SAP response time, work processes. Pool >90% => Critical P1.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        { "refId": "A", "expr": "sap_rfc_pool_utilisation{environment=\"$environment\"}", "legendFormat": "RFC pool %" },
        { "refId": "B", "expr": "sap_response_time_ms{environment=\"$environment\"}", "legendFormat": "response ms" },
        { "refId": "C", "expr": "sap_work_process_available{environment=\"$environment\"}", "legendFormat": "work processes free" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] }
        }
      }
    },
    {
      "id": 8,
      "title": "MON-008 FinSight API Health",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "FinSight API response ms, rate-limit remaining, token TTL. Headroom <10% => P2.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "targets": [
        { "refId": "A", "expr": "finsight_api_response_ms{environment=\"$environment\"}", "legendFormat": "response ms" },
        { "refId": "B", "expr": "finsight_rate_limit_remaining{environment=\"$environment\"} / finsight_rate_limit_total{environment=\"$environment\"} * 100", "legendFormat": "rate-limit headroom %" },
        { "refId": "C", "expr": "finsight_token_expiry_seconds{environment=\"$environment\"}", "legendFormat": "token TTL s" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 10 } ] }
        }
      }
    },
    {
      "id": 9,
      "title": "MON-009 Data Freshness",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Age of last successful load per domain vs 4h SLA. Exceeds SLA => P3.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "targets": [
        { "refId": "A", "expr": "(time() - max(last_successful_load_timestamp{domain=~\"$domain\",environment=\"$environment\"}) by (domain))", "legendFormat": "{{domain}}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 7200 }, { "color": "red", "value": 14400 } ] }
        }
      }
    },
    {
      "id": 10,
      "title": "MON-010 Resource Utilisation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Node CPU/memory/disk/network. Any >90% => P2 High.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "targets": [
        { "refId": "A", "expr": "node_cpu_utilisation{environment=\"$environment\"}", "legendFormat": "CPU {{instance}}" },
        { "refId": "B", "expr": "node_memory_utilisation{environment=\"$environment\"}", "legendFormat": "Mem {{instance}}" },
        { "refId": "C", "expr": "node_disk_utilisation{environment=\"$environment\"}", "legendFormat": "Disk {{instance}}" },
        { "refId": "D", "expr": "rate(node_network_bytes{environment=\"$environment\"}[5m])", "legendFormat": "Net {{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 90 } ] }
        }
      }
    },
    {
      "id": 11,
      "title": "MON-011 Kafka Consumer Lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-topic/partition consumer lag. >50K msgs => P2 High.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "targets": [
        { "refId": "A", "expr": "kafka_consumer_group_lag{topic!=\"dlq\",environment=\"$environment\"}", "legendFormat": "{{topic}} p{{partition}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 50000 } ] }
        }
      }
    },
    {
      "id": 12,
      "title": "MON-012 Circuit Breaker Status",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-service circuit breaker state: 0=Closed, 1=Open, 2=Half-Open. Any Open => P2.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 45 },
      "targets": [
        { "refId": "A", "expr": "circuit_breaker_state{environment=\"$environment\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Closed", "color": "green" }, "1": { "text": "Open", "color": "red" }, "2": { "text": "Half-Open", "color": "yellow" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 }, { "color": "yellow", "value": 2 } ] }
        }
      }
    }
  ]
}
